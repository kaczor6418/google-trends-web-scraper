## Scraper env

# Browser Config
CHROME_DEBUG_URL=http://localhost:9222
DOWNLOAD_TEMP_DIR=./temp_downloads

# Backend API Config
BACKEND_API_URL=http://localhost:3000/api/v1/trends/ingest

# Scraper Behavior
MIN_DELAY=2000
MAX_DELAY=5000

##########################
#-------------------------
##########################

# ScraperService env

# Database Credentials
POSTGRES_USER=my_secure_user
POSTGRES_PASSWORD=my_secure_password
POSTGRES_DB=trends_db

# PGAdmin Configuration
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=my_admin_password

# Database URL for Prisma (formatted for the container network)
DATABASE_URL=postgresql://my_secure_user:my_secure_password@db:5432/trends_db?schema=public