generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma-client"
}

datasource db {
  provider = "postgresql"
}

enum DictionaryType {
  ofertowy
  popularnonaukowy
  @@map("dictionary_type")
}

enum LongtailSource {
  openai
  trends
  manual
  import
  @@map("longtail_source")
}

enum TrendQueryGroup {
  top
  rising
  unknown
  @@map("trend_query_group")
}

enum TrendAlertStatus {
  open
  seen
  dismissed
  @@map("trend_alert_status")
}

enum ArticleStatus {
  draft
  published
  @@map("article_status")
}

model DictionaryWord {
  id               BigInt           @id @default(autoincrement())
  type             DictionaryType
  word             String
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @default(now()) @updatedAt @map("updated_at")
  longtailPhrases  LongtailPhrase[]
  articles         Article[]

  @@unique([type, word], name: "type_word") // Maps to your custom unique index
  @@index([type], map: "idx_dictionary_words_type")
  @@map("dictionary_words")
}

model LongtailPhrase {
  id                 BigInt           @id @default(autoincrement())
  dictionaryWordId   BigInt           @map("dictionary_word_id")
  phrase             String
  phraseNorm         String           @map("phrase_norm")
  geo                String           @default("PL")
  language           String           @default("pl")
  source             LongtailSource   @default(manual)
  active             Boolean          @default(true)
  alertThresholdPct  Float?           @map("alert_threshold_pct")
  createdAt          DateTime         @default(now()) @map("created_at")
  
  dictionaryWord     DictionaryWord   @relation(fields: [dictionaryWordId], references: [id], onDelete: Cascade)
  phraseTrends       PhraseTrend[]
  trendAlerts        TrendAlert[]
  articles           Article[]

  @@unique([dictionaryWordId, phraseNorm], name: "dictionary_word_id_phrase_norm")
  @@index([active], map: "idx_longtail_active")
  @@index([dictionaryWordId], map: "idx_longtail_dictionary")
  @@index([geo], map: "idx_longtail_geo")
  @@index([active, geo], map: "idx_longtail_active_geo")
  @@map("longtail_phrases")
}

model PhraseTrend {
  id                BigInt              @id @default(autoincrement())
  longtailPhraseId  BigInt              @map("longtail_phrase_id")
  snapshotDate      DateTime            @default(dbgenerated("CURRENT_DATE")) @map("snapshot_date") @db.Date
  geo               String              @default("PL")
  timeframeLabel    String              @map("timeframe_label")
  timeframeParam    String              @map("timeframe_param")
  windowDays        Int                 @default(30) @map("window_days")
  extractedAt       DateTime            @map("extracted_at")
  points            Int                 @default(0)
  mean              Float?
  slope             Float?
  changePct         Float?              @map("change_pct")
  score             Float?
  rawSeries         Json?               @map("raw_series")
  createdAt         DateTime            @default(now()) @map("created_at")

  longtailPhrase    LongtailPhrase      @relation(fields: [longtailPhraseId], references: [id], onDelete: Cascade)
  relatedQueries    TrendRelatedQuery[]
  trendAlerts       TrendAlert[]

  @@unique([longtailPhraseId, snapshotDate, geo, timeframeParam], name: "longtail_phrase_id_snapshot_date_geo_timeframe_param")
  @@index([snapshotDate(sort: Desc)], map: "idx_phrase_trends_date")
  @@index([longtailPhraseId, snapshotDate(sort: Desc)], map: "idx_phrase_trends_phrase_date")
  @@map("phrase_trends")
}

model TrendRelatedQuery {
  id             BigInt          @id @default(autoincrement())
  phraseTrendId  BigInt          @map("phrase_trend_id")
  groupType      TrendQueryGroup @default(unknown) @map("group_type")
  rank           Int
  query          String
  searchInterest Int?            @map("search_interest")
  increasePct    Float?          @map("increase_pct")
  isBreakout     Boolean         @default(false) @map("is_breakout")
  createdAt      DateTime        @default(now()) @map("created_at")

  phraseTrend    PhraseTrend     @relation(fields: [phraseTrendId], references: [id], onDelete: Cascade)

  @@unique([phraseTrendId, groupType, query], name: "phrase_trend_id_group_type_query")
  @@index([phraseTrendId, groupType, rank], map: "idx_trend_related_queries_snapshot_group_rank")
  @@map("trend_related_queries")
}

model TrendAlert {
  id               BigInt           @id @default(autoincrement())
  longtailPhraseId BigInt           @map("longtail_phrase_id")
  phraseTrendId    BigInt?          @map("phrase_trend_id")
  threshold        Float            @default(20)
  changePct        Float            @map("change_pct")
  status           TrendAlertStatus @default(open)
  createdAt        DateTime         @default(now()) @map("created_at")
  alertDay         DateTime         @default(dbgenerated("CURRENT_DATE")) @map("alert_day") @db.Date
  seenAt           DateTime?        @map("seen_at")

  longtailPhrase   LongtailPhrase   @relation(fields: [longtailPhraseId], references: [id], onDelete: Cascade)
  phraseTrend      PhraseTrend?     @relation(fields: [phraseTrendId], references: [id], onDelete: SetNull)

  @@unique([longtailPhraseId, alertDay], name: "longtail_phrase_id_alert_day")
  @@index([status, createdAt(sort: Desc)], map: "idx_trend_alerts_status_created")
  @@index([longtailPhraseId, createdAt(sort: Desc)], map: "idx_trend_alerts_phrase_created")
  @@map("trend_alerts")
}

model Article {
  id               BigInt          @id @default(autoincrement())
  longtailPhraseId BigInt?         @map("longtail_phrase_id")
  dictionaryWordId BigInt?         @map("dictionary_word_id")
  title            String
  titleNorm        String          @map("title_norm")
  status           ArticleStatus   @default(draft)
  content          String?
  createdAt        DateTime        @default(now()) @map("created_at")
  publishedAt      DateTime?       @map("published_at")

  longtailPhrase   LongtailPhrase? @relation(fields: [longtailPhraseId], references: [id], onDelete: SetNull)
  dictionaryWord   DictionaryWord? @relation(fields: [dictionaryWordId], references: [id], onDelete: SetNull)

  @@unique([titleNorm], name: "uq_articles_title_norm")
  @@index([status, createdAt(sort: Desc)], map: "idx_articles_status_created")
  @@index([longtailPhraseId], map: "idx_articles_longtail")
  @@map("articles")
}